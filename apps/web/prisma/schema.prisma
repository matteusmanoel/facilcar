// Auto Dealer MVP - Prisma schema v1
// Tabelas no schema PostgreSQL `facilcar` (convive com outros apps no mesmo projeto Supabase).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["facilcar"]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  LEAD_MANAGER

  @@schema("facilcar")
}

enum VehicleStatus {
  DRAFT
  PUBLISHED
  RESERVED
  SOLD
  ARCHIVED

  @@schema("facilcar")
}

enum VehicleType {
  CAR
  MOTORCYCLE
  UTILITY
  OTHER

  @@schema("facilcar")
}

enum FuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
  OTHER

  @@schema("facilcar")
}

enum Transmission {
  MANUAL
  AUTOMATIC
  AUTOMATED
  CVT
  OTHER

  @@schema("facilcar")
}

enum LeadType {
  CONTACT
  VEHICLE_INTEREST
  FINANCING
  SELL_VEHICLE

  @@schema("facilcar")
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  QUALIFIED
  WON
  LOST
  SPAM

  @@schema("facilcar")
}

enum LeadSource {
  HOME
  CATALOG
  VEHICLE_PAGE
  CONTACT_PAGE
  FINANCING_PAGE
  SELL_PAGE
  BLOG
  UNKNOWN

  @@schema("facilcar")
}

enum LeadChannel {
  FORM
  WHATSAPP
  MANUAL

  @@schema("facilcar")
}

enum PageStatus {
  DRAFT
  PUBLISHED

  @@schema("facilcar")
}

enum PostStatus {
  DRAFT
  PUBLISHED

  @@schema("facilcar")
}

enum VehicleFeatureCategory {
  COMFORT
  SAFETY
  TECH
  EXTERIOR
  OTHER

  @@schema("facilcar")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  assignedLeads Lead[]

  @@schema("facilcar")
}

model Brand {
  id       String   @id @default(cuid())
  name     String   @unique
  slug     String   @unique
  logoUrl  String?
  isActive Boolean  @default(true)
  vehicles Vehicle[]

  @@schema("facilcar")
}

model Vehicle {
  id                String         @id @default(cuid())
  slug              String         @unique
  status            VehicleStatus
  type              VehicleType
  title             String
  shortDescription  String?
  description       String?
  brandId           String
  brand             Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model             String
  version           String?
  yearManufacture   Int?
  yearModel         Int?
  mileage           Int?
  fuelType          FuelType?
  transmission      Transmission?
  color             String?
  doors             Int?
  plateFinal        String?
  priceCash         Decimal?       @db.Decimal(12, 2)
  priceTradeIn      Decimal?       @db.Decimal(12, 2)
  pricePromotional  Decimal?       @db.Decimal(12, 2)
  city              String?
  state             String?
  featured          Boolean        @default(false)
  publishedAt       DateTime?
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  images            VehicleImage[]
  features          VehicleFeature[]
  leads             Lead[]
  financingRequests FinancingRequest[]

  @@schema("facilcar")
  @@index([status])
  @@index([featured])
  @@index([brandId])
  @@index([priceCash])
  @@index([fuelType])
  @@index([transmission])
  @@index([publishedAt])
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@schema("facilcar")
}

model VehicleFeature {
  id        String                 @id @default(cuid())
  vehicleId String
  vehicle   Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  label     String
  category  VehicleFeatureCategory
  sortOrder Int

  @@schema("facilcar")
}

model Lead {
  id               String       @id @default(cuid())
  type             LeadType
  status           LeadStatus   @default(NEW)
  source           LeadSource
  channel          LeadChannel
  name             String
  email            String?
  phone            String
  whatsapp         String?
  city             String?
  state            String?
  message          String?
  vehicleId        String?
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  assignedToUserId String?
  assignedToUser    User?        @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmTerm          String?
  utmContent       String?
  originUrl        String?
  metadataJson     Json?
  internalNote     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  financingRequest FinancingRequest?
  sellRequest      SellRequest?

  @@schema("facilcar")
  @@index([type])
  @@index([status])
  @@index([source])
  @@index([createdAt(sort: Desc)])
}

model FinancingRequest {
  id                  String    @id @default(cuid())
  leadId              String    @unique
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vehicleId           String?
  vehicle             Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  cpf                 String?
  birthDate           DateTime?
  hasDriverLicense    Boolean?
  downPayment         Decimal?  @db.Decimal(12, 2)
  desiredInstallments Int?
  monthlyIncome       Decimal?  @db.Decimal(12, 2)
  vehicleYear         Int?
  vehicleModel        String?
  occupation          String?
  notes               String?

  @@schema("facilcar")
}

model SellRequest {
  id              String   @id @default(cuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  brand           String?
  model           String?
  version         String?
  yearManufacture Int?
  yearModel       Int?
  mileage         Int?
  fuelType        String?
  transmission    String?
  observations    String?

  @@schema("facilcar")
}

model Page {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String?
  body            String
  status          PageStatus
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@schema("facilcar")
}

model BlogPost {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  excerpt       String?
  coverImageUrl String?
  body          String
  status        PostStatus
  publishedAt   DateTime?
  metaTitle     String?
  metaDescription String?
  createdAt     DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@schema("facilcar")
}

model SiteSettings {
  id                   String   @id @default(cuid())
  siteName             String
  defaultWhatsappNumber String
  defaultEmail         String
  phoneNumber         String?
  addressLine         String?
  city                String?
  state               String?
  zipCode             String?
  facebookUrl         String?
  instagramUrl       String?
  youtubeUrl          String?
  seoDefaultTitle     String?
  seoDefaultDescription String?
  footerText          String?
  heroTitle           String?
  heroSubtitle        String?

  @@schema("facilcar")
}
