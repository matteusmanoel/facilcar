# === Obrigatórias (MVP) ===
# Postgres — local Docker (raiz: docker compose up -d db):
# DATABASE_URL="postgres://postgres:postgres@localhost:5432/facilcar?schema=public"
# Produção (ex. Neon):
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth.js — sem AUTH_SECRET o login admin não funciona (gerar: openssl rand -base64 32)
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# === Recomendadas ===
# Use a porta exibida pelo Next (3000 ou 3001 se 3000 estiver ocupada)
AUTH_URL="http://localhost:3000"

# Public
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="5545999999999"

# Optional: Storage (R2/S3)
# STORAGE_ENDPOINT=
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=

# Optional: Resend (notificação de leads)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# LEAD_NOTIFY_EMAIL= (destino dos alertas; default = RESEND_FROM_EMAIL)

# R2 public URL base (após upload via presign)
# STORAGE_PUBLIC_URL=https://pub-xxx.r2.dev

# Optional: Turnstile
# CAPTCHA_SITE_KEY=
# CAPTCHA_SECRET_KEY=

# Optional: PostHog
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Optional: Sentry
# SENTRY_DSN=
