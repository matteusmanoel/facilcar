# === Obrigatórias (MVP) ===
# Postgres — schema `facilcar` (não use ?schema= na URL; o Prisma qualifica as tabelas).
#
# Local (Docker / Postgres na máquina):
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/facilcar"
# Depois: npx prisma migrate deploy && npm run db:seed
#
# Supabase — Settings → Database → Connection string (URI). Substitua [YOUR-PASSWORD].
# Produção na Vercel: prefira o pooler (Transaction mode) para não esgotar conexões:
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# Conexão direta (migrations / dev):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# Último recurso se TLS falhar na Vercel (menos rigoroso): DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Auth.js — sem AUTH_SECRET o login admin não funciona (gerar: openssl rand -base64 32)
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# === Recomendadas ===
# URL canônica do site (local ou produção)
AUTH_URL="http://localhost:3000"

# Public
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="5545999999999"

# Hostname do projeto Supabase (só o host, sem https://) — usado em next/image para fotos no Storage
# Ex.: xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_HOST=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Storage — Cloudflare R2 OU Supabase Storage (API S3)
# Supabase: Project Settings → Storage → S3 connection (Access Key + Secret)
# STORAGE_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_BUCKET_NAME=vehicle-images
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# URL pública dos objetos (bucket público "vehicle-images"):
# STORAGE_PUBLIC_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/vehicle-images
#
# R2 (alternativa):
# STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=https://pub-xxx.r2.dev

# Optional: Resend (notificação de leads)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# LEAD_NOTIFY_EMAIL=

# Optional: Turnstile
# CAPTCHA_SITE_KEY=
# CAPTCHA_SECRET_KEY=

# Optional: PostHog
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Optional: Sentry
# SENTRY_DSN=

# Playwright E2E (npm run test:e2e) — credenciais de um usuário admin válido
# E2E_ADMIN_EMAIL="admin@example.com"
# E2E_ADMIN_PASSWORD="your-password"
